# Copy this file to .env and fill in real values.


# Generate a new one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts, e.g. example.com,www.example.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted origins for CSRF, required when DEBUG=False
# and you are behind HTTPS, e.g. https://example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Set to True only when serving over HTTPS in production
DJANGO_SECURE_SSL_REDIRECT=False
